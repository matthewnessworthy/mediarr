{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mediarr",
  "version": "0.1.0",
  "identifier": "com.mediarr.app",
  "bundle": {
    "createUpdaterArtifacts": true
  },
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../frontend/build"
  },
  "app": {
    "windows": [
      {
        "title": "Mediarr",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_GENERATED_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/matthewnessworthy/mediarr/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
